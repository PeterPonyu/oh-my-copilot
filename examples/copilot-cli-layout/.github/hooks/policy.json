{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "mkdir -p .copilot-hooks && printf 'session started: %s\\n' \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\" >> .copilot-hooks/session.log",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "printf 'tool used: %s\\n' \"${COPILOT_TOOL_NAME:-unknown}\" >> .copilot-hooks/tools.log",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
